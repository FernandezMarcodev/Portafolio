---
const github = "https://github.com/FernandezMarcodev";
const linkedin =
  "https://www.linkedin.com/in/marco-valentin-fernandez-741222352/";
---

<section id="hero" class="hero reveal">
  <div class="hero-content">
    <div class="hero-text">
      <div class="badge-container">
        <span
          class="badge"
          data-es="Disponible para nuevos proyectos"
          data-en="Available for new projects"
          >Disponible para nuevos proyectos</span
        >
      </div>
      <h1 class="hero-title">Marco Valentín Fernández</h1>
      <h2
        class="hero-subtitle"
        data-es="Desarrollador Backend"
        data-en="Backend Developer"
      >
        Desarrollador Backend
      </h2>
      <p
        class="tagline"
        data-es="Estudiante de Licenciatura en Informática en la Universidad Nacional del Oeste (UNO). Enfoque en robustez, escalabilidad y calidad de software."
        data-en="Computer Science student at Universidad National del Oeste (UNO). Focused on robustness, scalability, and software quality."
      >
        Estudiante de Licenciatura en Informática en la <strong
          >Universidad Nacional del Oeste (UNO)</strong
        >.<br />
        Enfoque en <strong>robustez, escalabilidad y calidad</strong> de software.
      </p>

      <div class="hero-actions">
        <a
          href="/assets/cv.pdf"
          download
          class="btn btn-primary"
          data-es="Descargar CV"
          data-en="Download CV">Descargar CV</a
        >
        <div class="socials">
          <a href={github} target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href={linkedin} target="_blank" rel="noopener noreferrer"
            >LinkedIn</a
          >
        </div>
      </div>
    </div>
    <div class="hero-image">
      <div class="image-wrapper">
        <div class="image-glow"></div>
        <img
          src="/assets/images/perfil.jpeg"
          alt="Marco Valentín Fernández - Foto de Perfil"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 90vh;
    padding-top: 120px;
    position: relative;
    overflow: hidden;
  }

  .hero-content {
    display: flex;
    align-items: center;
    gap: 80px;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .hero-text {
    flex: 1;
  }

  .badge-container {
    margin-bottom: 24px;
  }

  .badge {
    color: var(--accent-green);
    background: rgba(178, 226, 162, 0.05);
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    border: 1px solid rgba(178, 226, 162, 0.2);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .badge::before {
    content: "";
    width: 8px;
    height: 8px;
    background: var(--accent-green);
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 10px var(--accent-green);
  }

  .hero-title {
    font-size: 4.5rem;
    line-height: 1;
    margin-bottom: 10px;
    font-weight: 800;
    letter-spacing: -2px;
  }

  .hero-subtitle {
    font-size: 2rem;
    text-align: left;
    margin-bottom: 30px;
    font-weight: 600;
    background: linear-gradient(
      90deg,
      var(--accent-green) 0%,
      var(--accent-red) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .tagline {
    font-size: 1.25rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin-bottom: 40px;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .btn {
    padding: 16px 32px;
    border-radius: 12px;
    font-weight: 700;
    font-size: 1rem;
    transition: var(--transition);
    cursor: pointer;
  }

  .btn-primary {
    background-color: var(--accent-green);
    color: var(--bg-color);
    box-shadow: 0 10px 30px -10px rgba(178, 226, 162, 0.4);
  }

  .btn-primary:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -10px rgba(178, 226, 162, 0.6);
  }

  .socials {
    display: flex;
    gap: 24px;
  }

  .socials a {
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 1rem;
    position: relative;
    padding: 5px 0;
  }

  .socials a::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent-green);
    transition: var(--transition);
  }

  .socials a:hover {
    color: var(--text-primary);
  }

  .socials a:hover::after {
    width: 100%;
  }

  .hero-image {
    flex: 0 0 380px;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 60px;
    position: relative;
    z-index: 2;
    border: 2px solid var(--accent-green);
    box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.5), 0 0 30px rgba(178, 226, 162, 0.2);
    transition: var(--transition);
    animation: imagePulse 3s ease-in-out infinite;
  }

  .image-wrapper img:hover {
    transform: scale(1.03);
    box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.5), 0 0 40px rgba(178, 226, 162, 0.4);
  }

  @keyframes imagePulse {
    0%, 100% {
      box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.5), 0 0 30px rgba(178, 226, 162, 0.2);
    }
    50% {
      box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.5), 0 0 50px rgba(178, 226, 162, 0.35);
    }
  }

  .image-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120%;
    height: 120%;
    background: radial-gradient(
      circle,
      rgba(178, 226, 162, 0.15) 0%,
      transparent 70%
    );
    z-index: 1;
    pointer-events: none;
    animation: glowPulse 3s ease-in-out infinite;
  }

  @keyframes glowPulse {
    0%, 100% {
      opacity: 0.6;
    }
    50% {
      opacity: 1;
    }
  }

  @media (max-width: 1024px) {
    .hero-content {
      flex-direction: column-reverse;
      text-align: center;
      gap: 60px;
    }

    .hero-subtitle {
      text-align: center;
    }
    .hero-actions {
      justify-content: center;
      flex-direction: column;
      gap: 20px;
    }
    .hero-image {
      flex: 0 0 320px;
      width: 320px;
    }
    .hero-title {
      font-size: 3rem;
    }
    .tagline {
      margin: 0 auto 40px;
    }
  }
</style>
