---
const email = "fernandezmarcovalentin@gmail.com";
const linkedin =
  "https://www.linkedin.com/in/marco-valentin-fernandez-741222352/";
const github = "https://github.com/FernandezMarcodev";
const phone = "+54 9 11 5940 8162";
const whatsapp = `https://wa.me/5491159408162`;
---

<section id="contact" class="contact reveal">
  <div class="contact-header">
    <h2 data-es="¿Hablamos?" data-en="Let's Talk?">¿Hablamos?</h2>
    <p
      data-es="Estoy siempre abierto a nuevas oportunidades de colaboración en proyectos backend, automatización QA o ingeniería de software."
      data-en="I'm always open to new opportunities for collaboration in backend projects, QA automation, or software engineering."
    >
      Estoy siempre abierto a nuevas oportunidades de colaboración en proyectos
      backend, automatización QA o ingeniería de software.
    </p>
  </div>

  <div class="contact-grid">
    <div class="contact-methods">
      <a href={`mailto:${email}`} class="method" target="_blank">
        <span class="method-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m22 7-14 9.5-14-9.5"></path>
          </svg>
        </span>
        <div class="method-text">
          <span data-es="Email" data-en="Email">Email</span>
          <strong>{email}</strong>
        </div>
      </a>

      <a href={linkedin} target="_blank" class="method">
        <span class="method-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
          </svg>
        </span>
        <div class="method-text">
          <span>LinkedIn</span>
          <strong>Marco Valentín Fernández</strong>
        </div>
      </a>

      <a href={github} target="_blank" class="method">
        <span class="method-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </span>
        <div class="method-text">
          <span>GitHub</span>
          <strong>FernandezMarcodev</strong>
        </div>
      </a>

      <a href={whatsapp} target="_blank" class="method">
        <span class="method-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004a9.87 9.87 0 00-4.781 1.158l-.341.201-3.52.964.983-3.584-.23-.364a9.816 9.816 0 01.496-6.984 9.862 9.862 0 0113.196 3.684A9.837 9.837 0 0120.02 21h.002c0 5.518-4.482 10-10 10-1.704 0-3.352-.421-4.785-1.228l-.346-.19-3.588.975.962-3.51-.232-.364a9.833 9.833 0 01-.676-4.703 9.848 9.848 0 012.68-6.98 9.862 9.862 0 0113.704-1.067"/>
          </svg>
        </span>
        <div class="method-text">
          <span data-es="WhatsApp" data-en="WhatsApp">WhatsApp</span>
          <strong>{phone}</strong>
        </div>
      </a>

      <a href="/assets/cv.pdf" download class="method method-cv">
        <span class="method-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
        </span>
        <div class="method-text">
          <span data-es="Descargar CV" data-en="Download CV">Descargar CV</span>
          <strong data-es="Currículo Vitae" data-en="Curriculum Vitae">Currículo Vitae</strong>
        </div>
      </a>
    </div>

    <div class="contact-form">
      <div class="form-container">
        <h3 data-es="Enviame un mensaje" data-en="Send me a message">
          Enviame un mensaje
        </h3>
        <form id="contactForm">
          <div class="input-group">
            <label for="from_name" data-es="Nombre" data-en="Name">Nombre</label
            >
            <input
              type="text"
              id="from_name"
              name="from_name"
              placeholder="Tu nombre"
              data-es-placeholder="Tu nombre"
              data-en-placeholder="Your name"
              required
            />
          </div>

          <div class="input-group">
            <label for="from_email" data-es="Email" data-en="Email">Email</label
            >
            <input
              type="email"
              id="from_email"
              name="from_email"
              placeholder="tu@email.com"
              data-es-placeholder="tu@email.com"
              data-en-placeholder="you@email.com"
              required
            />
          </div>

          <div class="input-group">
            <label for="message" data-es="Mensaje" data-en="Message"
              >Mensaje</label
            >
            <textarea
              id="message"
              name="message"
              placeholder="¿En qué puedo ayudarte?"
              data-es-placeholder="¿En qué puedo ayudarte?"
              data-en-placeholder="How can I help you?"
              rows="5"
              required></textarea>
          </div>

          <button type="submit" class="submit-btn" id="submitBtn">
            <span data-es="Enviar Mensaje" data-en="Send Message"
              >Enviar Mensaje</span
            >
          </button>
          <p class="form-status" id="formStatus"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const CONFIG = {
    PUBLIC_KEY: "fiHO4iDbvyGhMSNdH",
    SERVICE_ID: "service_4q7xrvi",
    TEMPLATE_ID: "template_grjnf3o",
  };

  const loadEmailJS = (): Promise<any> => {
    return new Promise((resolve, reject) => {
      const win = window as any;
      if (win.emailjs) {
        resolve(win.emailjs);
        return;
      }
      const script = document.createElement("script");
      script.src =
        "https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js";
      script.onload = () => resolve(win.emailjs);
      script.onerror = reject;
      document.head.appendChild(script);
    });
  };

  const contactForm = document.getElementById(
    "contactForm",
  ) as HTMLFormElement | null;
  const submitBtn = document.getElementById(
    "submitBtn",
  ) as HTMLButtonElement | null;
  const formStatus = document.getElementById(
    "formStatus",
  ) as HTMLElement | null;

  if (contactForm && submitBtn && formStatus) {
    contactForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      const originalHTML = submitBtn.innerHTML;
      const lang = document.documentElement.lang;

      submitBtn.innerHTML = lang === "es" ? "⏳ Enviando..." : "⏳ Sending...";
      submitBtn.disabled = true;
      formStatus.textContent = "";

      try {
        const emailjsInstance = await loadEmailJS();
        emailjsInstance.init(CONFIG.PUBLIC_KEY);
        await emailjsInstance.sendForm(
          CONFIG.SERVICE_ID,
          CONFIG.TEMPLATE_ID,
          contactForm,
        );

        formStatus.innerText =
          lang === "es"
            ? "✅ ¡Mensaje enviado con éxito!"
            : "✅ Message sent successfully!";
        formStatus.className = "form-status success";
        contactForm.reset();
      } catch (error) {
        console.error("EmailJS Error:", error);
        formStatus.innerText =
          lang === "es"
            ? "❌ Error al enviar. Revisá tu conexión o configuración."
            : "❌ Error sending. Check your connection or configuration.";
        formStatus.className = "form-status error";
      } finally {
        submitBtn.innerHTML = originalHTML;
        submitBtn.disabled = false;
      }
    });
  }
</script>

<style>
  .contact {
    padding: 100px 20px;
    background: linear-gradient(
      180deg,
      var(--bg-color) 0%,
      var(--bg-secondary) 100%
    );
    border-radius: 40px;
    margin: 50px auto 100px;
  }

  .contact-header {
    text-align: center;
    margin-bottom: 60px;
  }
  .contact-header h2 {
    font-size: 3.5rem;
    margin-bottom: 20px;
    background: linear-gradient(
      90deg,
      var(--text-primary),
      var(--text-secondary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .contact-header p {
    font-size: 1.25rem;
    color: var(--text-secondary);
    max-width: 700px;
    margin: 0 auto;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: stretch;
  }
  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .method {
    display: flex;
    align-items: center;
    gap: 20px;
    background: rgba(255, 255, 255, 0.03);
    padding: 24px;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: var(--transition);
  }
  .method:hover {
    border-color: var(--accent-green);
    transform: translateX(10px);
    background: rgba(178, 226, 162, 0.05);
  }
  .method-icon {
    font-size: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    color: var(--accent-green);
    flex-shrink: 0;
  }

  .method-icon svg {
    width: 28px;
    height: 28px;
  }

  .method-cv .method-icon {
    color: var(--accent-red);
  }

  .method-cv:hover {
    border-color: var(--accent-red);
    background: rgba(255, 138, 138, 0.05);
  }
  .method-text span {
    display: block;
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }
  .method-text strong {
    font-size: 1.1rem;
    color: var(--text-primary);
    word-break: break-all;
  }
  .form-container {
    background: var(--card-bg);
    padding: 40px;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .form-container h3 {
    font-size: 1.8rem;
    margin-bottom: 30px;
    color: var(--accent-red);
  }
  .input-group {
    margin-bottom: 22px;
  }
  .input-group label {
    display: block;
    margin-bottom: 10px;
    font-size: 0.95rem;
    color: var(--text-secondary);
  }
  .input-group input,
  .input-group textarea {
    width: 100%;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 16px;
    border-radius: 12px;
    color: white;
    font-family: inherit;
    font-size: 1rem;
    transition: var(--transition);
  }
  .input-group input:focus,
  .input-group textarea:focus {
    border-color: var(--accent-green);
    outline: none;
    box-shadow: 0 0 15px var(--accent-glow);
  }
  .input-group textarea {
    resize: none;
    min-height: 120px;
  }
  .submit-btn {
    width: 100%;
    padding: 18px;
    background: var(--accent-green);
    color: var(--bg-color);
    border: none;
    border-radius: 12px;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    transition: var(--transition);
    margin-top: auto;
  }
  .submit-btn:hover {
    transform: translateY(-4px);
    box-shadow: 0 15px 30px -10px var(--accent-green);
  }
  .form-status {
    text-align: center;
    margin-top: 18px;
    font-weight: 600;
  }
  .form-status.success {
    color: var(--accent-green);
  }
  .form-status.error {
    color: var(--accent-red);
  }
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
