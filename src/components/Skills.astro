        <!-- Columna derecha: Ingeniería -->
        <div class="skills-column">
            <h3
                class="column-title"
                data-es="Ingeniería de Software"
                data-en="Software Engineering"
            >
                Ingeniería de Software
            </h3>
            <div class="engineering-list">
                {
                    engineeringSkills.map((skill) => (
                        <div class="eng-card">
                            <div class="eng-text">
                                <strong
                                    data-es={skill.name.es}
                                    data-en={skill.name.en}
                                >
                                    {skill.name.es}
                                </strong>
                                <p
                                    data-es={skill.desc.es}
                                    data-en={skill.desc.en}
                                >
                                    {skill.desc.es}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<style>
    .skills {
        padding: 120px 20px;
        background: linear-gradient(
            135deg,
            rgba(22, 27, 34, 0.5) 0%,
            var(--bg-secondary) 100%
        );
        border-radius: 40px;
        margin: 50px auto;
        border: 1px solid rgba(255, 255, 255, 0.03);
    }

    .skills-header {
        text-align: center;
        margin-bottom: 70px;
    }

    .skills-header h2 {
        font-size: 3.5rem;
        margin-bottom: 16px;
        background: linear-gradient(
            90deg,
            var(--accent-green),
            var(--text-primary)
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .skills-header p {
        font-size: 1.2rem;
        color: var(--text-secondary);
        max-width: 620px;
        margin: 0 auto;
        line-height: 1.7;
    }

    .skills-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: stretch;
    }

    .skills-column {
        display: flex;
        flex-direction: column;
    }

    .column-title {
        font-size: 1.1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--accent-green);
        margin-bottom: 28px;
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(178, 226, 162, 0.15);
        text-align: center;
    }

    /* ── Herramientas ── */
    .tools-list {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: repeat(3, 1fr);
        gap: 12px;
        flex: 1;
    }

    .tool-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 16px;
        padding: 20px 12px;
        transition: var(--transition);
        cursor: default;
        text-align: center;
    }

    .tool-card:hover {
        background: rgba(178, 226, 162, 0.08);
        border-color: var(--accent-green);
        transform: translateY(-4px);
    }

    .tool-logo {
        width: 40px;
        height: 40px;
        flex-shrink: 0;
    }

    .tool-name {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--text-primary);
        line-height: 1.2;
    }

    /* ── Ingeniería ── */
    .engineering-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        flex: 1;
    }

    .eng-card {
        display: flex;
        align-items: flex-start;
        gap: 16px;
