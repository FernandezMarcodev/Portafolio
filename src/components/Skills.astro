---
const engineeringSkills = [
    {
        name: { es: "Análisis de Requisitos", en: "Requirements Analysis" },
        desc: {
            es: "IEEE 830, historias de usuario e ingeniería de requerimientos.",
            en: "IEEE 830, user stories and requirements engineering.",
        },
    },
    {
        name: { es: "Diagramas UML", en: "UML Diagrams" },
        desc: {
            es: "Casos de uso, clases, secuencia, actividad y despliegue.",
            en: "Use cases, class, sequence, activity and deployment diagrams.",
        },
    },
    {
        name: { es: "Diagramas DER", en: "ERD / Data Modeling" },
        desc: {
            es: "Modelado entidad-relación y diseño de bases de datos.",
            en: "Entity-relationship modeling and database design.",
        },
    },
    {
        name: { es: "Testing & QA", en: "Testing & QA" },
        desc: {
            es: "Planes de prueba, casos de prueba y automatización de flujos.",
            en: "Test plans, test cases and flow automation.",
        },
    },
    {
        name: { es: "Diseño de Sistemas", en: "System Design" },
        desc: {
            es: "Arquitectura de software, escalabilidad y patrones de diseño.",
            en: "Software architecture, scalability and design patterns.",
        },
    },
    {
        name: { es: "Despliegue y Validación", en: "Deployment & Validation" },
        desc: {
            es: "CI/CD básico, Docker Compose y validación de entornos.",
            en: "Basic CI/CD, Docker Compose and environment validation.",
        },
    },
];
---

<section id="skills" class="skills reveal">
    <div class="skills-header">
        <h2 data-es="Habilidades" data-en="Skills">Habilidades</h2>
        <p
            data-es="Herramientas que uso día a día y fundamentos de ingeniería que aplico en cada proyecto."
            data-en="Tools I use every day and engineering fundamentals I apply in every project."
        >
            Herramientas que uso día a día y fundamentos de ingeniería que
            aplico en cada proyecto.
        </p>
    </div>

    <div class="skills-grid">
        <!-- Columna izquierda: Herramientas -->
        <div class="skills-column">
            <h3 class="column-title" data-es="Herramientas" data-en="Tools">
