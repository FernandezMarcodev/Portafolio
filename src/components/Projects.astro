---
const projects = [
  {
    name: {
      es: "Bot de WhatsApp - Sistema de Turnos",
      en: "WhatsApp Bot - Appointment System",
    },
    description: {
      es: "Bot de WhatsApp que gestiona los turnos de una barbería, brindando disponibilidad 24/7. Permite agendar, cancelar y consultar turnos de forma automatizada.",
      en: "WhatsApp bot that manages barbershop appointments, providing 24/7 availability. Allows scheduling, canceling and querying appointments automatically.",
    },
    techStack: ["Python", "FastAPI", "WhatsApp API TWILIO", "PostgreSQL"],
    repo: "https://github.com/FernandezMarcodev/whatsapp-bot",
    img: "/assets/images/project-barberbot.jpeg",
    docs: "/assets/docs/barber-bot-docs.pdf",
  },
  {
    name: {
      es: "Carritos Abandonados - Tienda Nube",
      en: "Abandoned Carts - Tienda Nube",
    },
    description: {
      es: "Sistema que guarda los carritos abandonados y envía notificaciones a los usuarios. Consume la API de Tienda Nube para sincronizar productos y recuperar ventas.",
      en: "System that saves abandoned carts and sends notifications to users. Consumes the Tienda Nube API to sync products and recover sales.",
    },
    techStack: ["Python", "FastAPI", "Tienda Nube API", "PostgreSQL"],
    repo: "https://github.com/FernandezMarcodev/Abandoned-Carts",
    img: "/assets/images/project-abandonedcarts.jpeg",
    docs: "/assets/docs/abandoned-carts-docs.pdf",
  },
];
---

<section id="projects" class="projects-section reveal">
  <div class="projects-header">
    <h2 data-es="Proyectos Destacados" data-en="Featured Projects">
      Proyectos Destacados
    </h2>
    <p
      data-es="Una selección de trabajos que demuestran mis habilidades en desarrollo y calidad."
      data-en="A selection of works that demonstrate my development and quality skills."
    >
      Una selección de trabajos que demuestran mis habilidades en desarrollo y
      calidad.
    </p>
  </div>

  <div class="projects-grid">
    {
      projects.map((project) => (
        <div class="project-card">
          <div class="project-image">
            <img src={project.img} alt={project.name.es} loading="lazy" />
          </div>
          <div class="project-info">
            <div class="project-buttons">
              <a
                href={project.repo}
                target="_blank"
                class="btn-repo"
                data-es="Link al repositorio"
                data-en="Link to repository"
              >
                Link al repositorio
              </a>
              <a
                href={project.docs}
                target="_blank"
                class="btn-docs"
                data-es="Ver documentación"
                data-en="View documentation"
              >
                Ver documentación
              </a>
            </div>
            <div class="project-tags">
              {project.techStack.map((tech) => (
                <span class="tag">{tech}</span>
              ))}
            </div>
            <h3 data-es={project.name.es} data-en={project.name.en}>
              {project.name.es}
            </h3>
            <p
              data-es={project.description.es}
              data-en={project.description.en}
            >
              {project.description.es}
            </p>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .projects-section {
    padding-bottom: 200px;
  }

  .projects-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .projects-header p {
    color: var(--text-secondary);
    font-size: 1.2rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 40px;
  }

  .project-card {
    background: var(--card-bg);
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
  }

  .project-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.6);
    border-color: rgba(178, 226, 162, 0.2);
  }

  .project-image {
    position: relative;
    height: 250px;
    overflow: hidden;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .project-card:hover .project-image img {
    transform: scale(1.1);
  }

  .project-buttons {
    display: flex;
    gap: 12px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .btn-repo,
  .btn-docs {
    padding: 12px 20px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: var(--transition);
    text-align: center;
    flex: 1;
    min-width: 140px;
  }

  .btn-repo {
    background: var(--accent-green);
    color: var(--bg-color);
  }

  .btn-repo:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px -10px rgba(178, 226, 162, 0.4);
  }

  .btn-docs {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-primary);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .btn-docs:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--accent-green);
    transform: translateY(-2px);
  }

  .project-info {
    padding: 30px;
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 20px;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.05);
    color: var(--accent-green);
    padding: 6px 12px;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .project-info h3 {
    font-size: 1.8rem;
    margin-bottom: 12px;
    font-weight: 800;
    color: var(--text-primary);
  }

  .project-info p {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
